{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "E-Brochure Static Server (Python)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8080"],
      "port": 8080
    },
    {
      "name": "E-Brochure Static Server (npx serve)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-p", "3000", "."],
      "port": 3000
    }
  ]
}
